<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Adicionado %highlight para cores e %cyan para o logger, facilitando a leitura no terminal -->
            <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Nível global alterado para DEBUG para ver detalhes do Ktor e Serialization -->
    <root level="DEBUG">
        <appender-ref ref="STDOUT" />
    </root>

    <!-- Força DEBUG especificamente no seu pacote de estudo -->
    <logger name="com.builder.study" level="DEBUG"/>
    
    <!-- Reduz o ruído de bibliotecas muito verbosas se necessário -->
    <logger name="io.netty" level="INFO"/>
</configuration>
