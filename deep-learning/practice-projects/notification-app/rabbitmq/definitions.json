{
  "vhosts": [
    { "name": "/" }
  ],
  "exchanges": [
    {
      "name": "my-exchange",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false
    }
  ],
  "queues": [
    {
      "name": "my-queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "my-exchange-dlx",
        "x-dead-letter-routing-key": "my-queue-dlq"
      }
    },
    {
      "name": "my-queue-dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "my-exchange",
      "vhost": "/",
      "destination": "my-queue",
      "destination_type": "queue",
      "routing_key": "my-routing-key",
      "arguments": {}
    }
  ],
  "users": [
    {
      "name": "guest",
      "password": "guest",
      "tags": "administrator"
    }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ]
}